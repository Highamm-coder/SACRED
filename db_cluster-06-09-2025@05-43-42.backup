--
-- Name: media_library Admins and editors can manage media; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Admins and editors can manage media" ON public.media_library USING ((EXISTS ( SELECT 1
   FROM public.profiles
  WHERE ((profiles.id = auth.uid()) AND ((profiles.role = 'admin'::text) OR (profiles.role = 'editor'::text))))));


