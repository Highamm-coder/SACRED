5-418c-9ff8-485806747cb3", "question_text": "How important is it that you are able to help your partner reach orgasm?", "response_type": "text", "response_value": "I am not sure this should be my responsibility"}, {"id": "595339b9-9e88-473a-ada0-f177afa1874e", "score": null, "section": "orgasm-pleasure", "metadata": {}, "created_at": "2025-08-19T16:05:18.77037+00:00", "updated_at": "2025-08-19T16:05:20.155387+00:00", "question_id": "masturbation", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "What are your thoughts about masturbation within marriage?", "response_type": "text", "response_value": "Believe this is not appropriate for married Christians"}]}, "frequency-desire": {"count": 0, "total": 0, "average": 0, "responses": [{"id": "5ba4e24a-adc8-4498-b465-c39589e30f22", "score": null, "section": "frequency-desire", "metadata": {}, "created_at": "2025-08-19T16:05:35.15523+00:00", "updated_at": "2025-08-19T16:05:36.407784+00:00", "question_id": "frequency", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "How often do you realistically want to have sex in marriage?", "response_type": "text", "response_value": "A few times per month"}, {"id": "8a281bed-d878-404d-8b89-5a81c88fbb2b", "score": null, "section": "frequency-desire", "metadata": {}, "created_at": "2025-08-19T16:05:38.106179+00:00", "updated_at": "2025-08-19T16:05:39.12349+00:00", "question_id": "higher-desire-partner", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "What if your partner wants sex significantly more often than you do?", "response_type": "text", "response_value": "I would worry there is something wrong with me"}, {"id": "6577e6b9-f3c3-4a8c-b16d-ad4c2f13f63a", "score": null, "section": "frequency-desire", "metadata": {}, "created_at": "2025-08-19T16:05:40.270924+00:00", "updated_at": "2025-08-19T16:05:41.423064+00:00", "question_id": "lower-desire-partner", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "What if your partner wants sex significantly less often than you do?", "response_type": "text", "response_value": "I would worry they do not find me attractive"}, {"id": "1b472cad-b8a2-41cf-92b4-900e827ebbfc", "score": null, "section": "frequency-desire", "metadata": {}, "created_at": "2025-08-19T16:05:42.57935+00:00", "updated_at": "2025-08-19T16:05:43.769768+00:00", "question_id": "initiation", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "How do you want to communicate when you are interested in having sex?", "response_type": "text", "response_value": "I am not sure how I will feel about initiating sex"}, {"id": "81e5bde4-258b-4a69-bd63-caf1ec3bf3e1", "score": null, "section": "frequency-desire", "metadata": {}, "created_at": "2025-08-19T16:05:44.889298+00:00", "updated_at": "2025-08-19T16:05:46.305595+00:00", "question_id": "rejection", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "What if you are not in the mood for sex when your partner initiates?", "response_type": "text", "response_value": "I would expect my partner to respect my no without question"}]}, "sexual-knowledge": {"count": 0, "total": 0, "average": 0, "responses": [{"id": "c2e38684-92d3-4754-94b2-2b54547cbf17", "score": null, "section": "sexual-knowledge", "metadata": {}, "created_at": "2025-08-19T16:04:23.622154+00:00", "updated_at": "2025-08-19T16:04:25.208496+00:00", "question_id": "sexual-experience-virginity", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "Are you a virgin, and have you and your partner discussed what virginity means to each of you?", "response_type": "text", "response_value": "Yes, I am a virgin and my partner knows this"}, {"id": "8ada3c44-eb65-46a1-8c1e-d712615ddaf8", "score": null, "section": "sexual-knowledge", "metadata": {}, "created_at": "2025-08-19T16:04:27.120899+00:00", "updated_at": "2025-08-19T16:04:28.354019+00:00", "question_id": "knowledge-level", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "How much do you actually know about what happens during sex?", "response_type": "text", "response_value": "I really do not know much about the actual experience"}, {"id": "8e20f1bd-6076-4517-ab22-ed61e2843f31", "score": null, "section": "sexual-knowledge", "metadata": {}, "created_at": "2025-08-19T16:04:29.70281+00:00", "updated_at": "2025-08-19T16:04:30.624763+00:00", "question_id": "pain-expectations", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "What are your expectations about pain during first-time sex?", "response_type": "text", "response_value": "I honestly have no idea what to expect and that makes me nervous"}, {"id": "c2cf559d-17cb-4069-9b0a-dec5d7a43d09", "score": null, "section": "sexual-knowledge", "metadata": {}, "created_at": "2025-08-19T16:04:31.519807+00:00", "updated_at": "2025-08-19T16:04:32.532281+00:00", "question_id": "orgasm-knowledge", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "Rate your knowledge about orgasms and sexual climax:", "response_type": "text", "response_value": "I understand the basics pretty well"}, {"id": "2b8c84ad-a8ba-4b93-af7f-63441b67a04f", "score": null, "section": "sexual-knowledge", "metadata": {}, "created_at": "2025-08-19T16:04:36.125471+00:00", "updated_at": "2025-08-19T16:04:37.370087+00:00", "question_id": "female-arousal", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "What do you know about how women get aroused and what they need to feel pleasure?", "response_type": "text", "response_value": "I have never really learned about this topic"}, {"id": "d4a2e364-e5a7-4e86-aef1-bf98b384008d", "score": null, "section": "sexual-knowledge", "metadata": {}, "created_at": "2025-08-19T16:04:38.326508+00:00", "updated_at": "2025-08-19T16:04:39.092232+00:00", "question_id": "male-arousal", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "What do you know about how men get aroused and what they need to feel satisfied?", "response_type": "text", "response_value": "I have never really learned about this topic"}]}, "communication-sex": {"count": 0, "total": 0, "average": 0, "responses": [{"id": "10786ad7-bb7b-47b6-9342-a40fa383f521", "score": null, "section": "communication-sex", "metadata": {}, "created_at": "2025-08-19T16:05:47.378176+00:00", "updated_at": "2025-08-19T16:05:48.548261+00:00", "question_id": "talking-comfort", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "How do you feel about talking during sexual intimacy?", "response_type": "text", "response_value": "I am not sure how I will feel about this in the moment"}, {"id": "e86f9eff-8f44-41d7-86ed-1b50bc74c431", "score": null, "section": "communication-sex", "metadata": {}, "created_at": "2025-08-19T16:05:50.298439+00:00", "updated_at": "2025-08-19T16:05:53.246841+00:00", "question_id": "discomfort-communication", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "What if something your partner does does not feel good or is uncomfortable?", "response_type": "text", "response_value": "I would be too embarrassed to say anything"}, {"id": "8d1b5505-b234-4264-9a85-1e5be82be6bb", "score": null, "section": "communication-sex", "metadata": {}, "created_at": "2025-08-19T16:05:55.079223+00:00", "updated_at": "2025-08-19T16:05:56.947936+00:00", "question_id": "pleasure-communication", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "How do you want your partner to tell you what they enjoy sexually?", "response_type": "text", "response_value": "I assume I will naturally know what feels good for them"}, {"id": "ae124ba4-c87d-443a-a13d-c2acc49b66e8", "score": null, "section": "communication-sex", "metadata": {}, "created_at": "2025-08-19T16:05:58.232135+00:00", "updated_at": "2025-08-19T16:05:59.563584+00:00", "question_id": "new-activities", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "What if you want to try something new sexually?", "response_type": "text", "response_value": "I would rather stick with basics than risk making them uncomfortable"}]}, "sexual-activities": {"count": 0, "total": 0, "average": 0, "responses": [{"id": "add1dc7b-6a51-4914-87a0-5b95156cb38e", "score": null, "section": "sexual-activities", "metadata": {}, "created_at": "2025-08-19T16:04:43.106661+00:00", "updated_at": "2025-08-19T16:04:43.983036+00:00", "question_id": "nudity-comfort", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "How do you feel about being completely naked during sex?", "response_type": "text", "response_value": "Does not appeal to me/want to say no"}, {"id": "fab66809-42f2-49f5-a27f-5efda3f4eeb2", "score": null, "section": "sexual-activities", "metadata": {}, "created_at": "2025-08-19T16:04:49.805665+00:00", "updated_at": "2025-08-19T16:04:51.042437+00:00", "question_id": "intercourse", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "How do you feel about having intercourse (penis in vagina)?", "response_type": "text", "response_value": "Does not appeal to me/want to say no"}, {"id": "d9045f76-782b-47e7-bb0b-2769c5ca3b1a", "score": null, "section": "sexual-activities", "metadata": {}, "created_at": "2025-08-19T16:04:52.238389+00:00", "updated_at": "2025-08-19T16:04:53.489239+00:00", "question_id": "manual-stimulation", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "How do you feel about using your hands to sexually pleasure your partner?", "response_type": "text", "response_value": "Does not appeal to me/want to say no"}, {"id": "75527c48-35c4-4b0f-bc8b-2009ffc804a3", "score": null, "section": "sexual-activities", "metadata": {}, "created_at": "2025-08-19T16:04:54.899665+00:00", "updated_at": "2025-08-19T16:04:56.30518+00:00", "question_id": "oral-sex", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "How do you feel about oral sex in marriage?", "response_type": "text", "response_value": "Does not appeal to me/want to say no"}, {"id": "11775a57-8671-4b85-b5d7-c783e155476d", "score": null, "section": "sexual-activities", "metadata": {}, "created_at": "2025-08-19T16:04:59.271171+00:00", "updated_at": "2025-08-19T16:05:00.440679+00:00", "question_id": "anal-sex", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "How do you feel about anal sex in marriage?", "response_type": "text", "response_value": "I have concerns about whether this fits our values"}, {"id": "951a8457-27d2-46f6-9336-94f65d6007be", "score": null, "section": "sexual-activities", "metadata": {}, "created_at": "2025-08-19T16:05:02.458096+00:00", "updated_at": "2025-08-19T16:05:03.550807+00:00", "question_id": "sexual-positions", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "How do you feel about having sex in different positions?", "response_type": "text", "response_value": "Like the idea of keeping things simple"}, {"id": "3efbccb9-6576-4116-9029-4c850dca148a", "score": null, "section": "sexual-activities", "metadata": {}, "created_at": "2025-08-19T16:05:05.151949+00:00", "updated_at": "2025-08-19T16:05:06.388627+00:00", "question_id": "talking-during-sex-activity", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "How do you feel about talking during sex?", "response_type": "text", "response_value": "Prefer to focus on the physical connection without much talking"}]}, "sexual-challenges": {"count": 0, "total": 0, "average": 0, "responses": [{"id": "604befd4-70fe-46b3-9065-7e542b8d4406", "score": null, "section": "sexual-challenges", "metadata": {}, "created_at": "2025-08-19T16:06:00.677291+00:00", "updated_at": "2025-08-19T16:06:01.755484+00:00", "question_id": "pain-response", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "What if you experience pain during penetration that does not improve quickly?", "response_type": "text", "response_value": "I would be too embarrassed to seek help"}, {"id": "83c01ab4-10ac-4ce5-8cb3-405d953b6912", "score": null, "section": "sexual-challenges", "metadata": {}, "created_at": "2025-08-19T16:06:04.635957+00:00", "updated_at": "2025-08-19T16:06:05.870653+00:00", "question_id": "orgasm-difficulty", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "What if one of you has difficulty reaching orgasm?", "response_type": "text", "response_value": "Accept that some people just do not climax easily"}, {"id": "dc5d5fcb-9138-4444-afb5-2944db9428a2", "score": null, "section": "sexual-challenges", "metadata": {}, "created_at": "2025-08-19T16:06:07.154928+00:00", "updated_at": "2025-08-19T16:06:08.362062+00:00", "question_id": "erectile-issues", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "What if you experience erectile dysfunction or premature ejaculation?", "response_type": "text", "response_value": "I would assume this means I am not attracted enough to my partner"}, {"id": "78fdff8d-4316-4963-9a9c-88d1ca56679a", "score": null, "section": "sexual-challenges", "metadata": {}, "created_at": "2025-08-19T16:06:09.58917+00:00", "updated_at": "2025-08-19T16:06:11.013983+00:00", "question_id": "expectations-vs-reality", "assessment_id": "a670a510-60e5-418c-9ff8-485806747cb3", "question_text": "What if your sex life does not meet your expectations in the first year?", "response_type": "text", "response_value": "I would worry that something is fundamentally wrong with our marriage"}]}}	{"partnerName": "Dawn", "partnerRole": "partner2", "weddingDate": "2025-08-20", "partner1Name": "Matthew", "partner2Name": "Dawn", "onboardingCompleted": true}	2025-08-19 16:02:02.486588+00	2025-08-19 16:06:11.993189+00	2025-08-19 16:06:11.797+00
