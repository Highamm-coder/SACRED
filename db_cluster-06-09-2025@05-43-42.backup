-- Name: misalignment_discussions Users can access their own misalignment discussions; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can access their own misalignment discussions" ON public.misalignment_discussions USING ((assessment_id IN ( SELECT couple_assessments.id
   FROM public.couple_assessments
  WHERE ((couple_assessments.partner1_email = auth.email()) OR (couple_assessments.partner2_email = auth.email())))));


