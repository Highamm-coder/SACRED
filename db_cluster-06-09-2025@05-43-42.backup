--

CREATE POLICY "Partners can update their assessments" ON public.couple_assessments FOR UPDATE USING (((partner1_email = ((auth.jwt())::json ->> 'email'::text)) OR (partner2_email = ((auth.jwt())::json ->> 'email'::text))));


