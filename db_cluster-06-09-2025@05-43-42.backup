-- Name: answers Users can view answers for their assessments; Type: POLICY; Schema: public; Owner: postgres
--

CREATE POLICY "Users can view answers for their assessments" ON public.answers FOR SELECT USING ((EXISTS ( SELECT 1
   FROM public.couple_assessments ca
  WHERE ((ca.id = answers.assessment_id) AND ((ca.partner1_email = ((auth.jwt())::json ->> 'email'::text)) OR (ca.partner2_email = ((auth.jwt())::json ->> 'email'::text)))))));


