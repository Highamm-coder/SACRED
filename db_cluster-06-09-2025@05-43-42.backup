303acc06-3e3d-4f42-9bae-1f9fbb080286	d11f1ca3-ce83-487c-8cb3-911be725efc6	matthew.higham1@gmail.com	Matthew's Assessment - Sacred Pre-Marriage	Matthew's perspective	completed	100	{"bodies-nudity": {"count": 0, "total": 0, "average": 0, "responses": [{"id": "d64f16c8-b688-4013-baeb-bdfa17e848ad", "score": null, "section": "bodies-nudity", "metadata": {}, "created_at": "2025-08-19T16:03:19.333722+00:00", "updated_at": "2025-08-19T16:03:23.006088+00:00", "question_id": "body-comfort-self", "assessment_id": "303acc06-3e3d-4f42-9bae-1f9fbb080286", "question_text": "How comfortable are you with your partner seeing your naked body?", "response_type": "text", "response_value": "Very comfortable - I want them to see and appreciate my body"}, {"id": "ef02c7a0-065b-4e2f-ba2a-7e08f31ca2cf", "score": null, "section": "bodies-nudity", "metadata": {}, "created_at": "2025-08-19T16:03:24.166326+00:00", "updated_at": "2025-08-19T16:03:25.342104+00:00", "question_id": "body-comfort-partner", "assessment_id": "303acc06-3e3d-4f42-9bae-1f9fbb080286", "question_text": "How comfortable are you with seeing your partner naked body?", "response_type": "text", "response_value": "Somewhat nervous but looking forward to it"}, {"id": "cbff7642-b59a-487e-af1b-14bc9117567a", "score": null, "section": "bodies-nudity", "metadata": {}, "created_at": "2025-08-19T16:03:26.235635+00:00", "updated_at": "2025-08-19T16:03:27.401775+00:00", "question_id": "body-hair", "assessment_id": "303acc06-3e3d-4f42-9bae-1f9fbb080286", "question_text": "What are your expectations about body hair and grooming for sexual intimacy?", "response_type": "text", "response_value": "Natural body hair is fine and normal"}, {"id": "27e98900-b1c2-4872-b1b7-10f147090498", "score": null, "section": "bodies-nudity", "metadata": {}, "created_at": "2025-08-19T16:03:29.026061+00:00", "updated_at": "2025-08-19T16:03:30.977326+00:00", "question_id": "menstruation", "assessment_id": "303acc06-3e3d-4f42-9bae-1f9fbb080286", "question_text": "How do you feel about menstruation affecting your sex life?", "response_type": "text", "response_value": "I have not really considered how this will affect our sex life"}]}, "orgasm-pleasure": {"count": 0, "total": 0, "average": 0, "responses": [{"id": "a4b824f6-ce84-44f2-8210-a02beb4f9986", "score": null, "section": "orgasm-pleasure", "metadata": {}, "created_at": "2025-08-19T16:02:53.255291+00:00", "updated_at": "2025-08-19T16:02:54.259702+00:00", "question_id": "orgasm-expectations", "assessment_id": "303acc06-3e3d-4f42-9bae-1f9fbb080286", "question_text": "What are your expectations about reaching orgasm?", "response_type": "text", "response_value": "Reaching orgasm is not a priority for me"}, {"id": "cd3274dc-43bd-4c20-929b-1c290844f1d8", "score": null, "section": "orgasm-pleasure", "metadata": {}, "created_at": "2025-08-19T16:02:55.665958+00:00", "updated_at": "2025-08-19T16:02:56.755357+00:00", "question_id": "orgasm-patience", "assessment_id": "303acc06-3e3d-4f42-9bae-1f9fbb080286", "question_text": "How do you feel about the possibility that reaching orgasm might take practice and patience?", "response_type": "text", "response_value": "Very anxious about sexual performance in general"}, {"id": "5fb5db5d-fa82-4864-8839-c936eeb5937e", "score": null, "section": "orgasm-pleasure", "metadata": {}, "created_at": "2025-08-19T16:03:00.59568+00:00", "updated_at": "2025-08-19T16:03:01.727791+00:00", "question_id": "orgasm-differences", "assessment_id": "303acc06-3e3d-4f42-9bae-1f9fbb080286", "question_text": "What if your partner reaches orgasm much more quickly/easily than you do?", "response_type": "text", "response_value": "I would be somewhat disappointed but understanding"}, {"id": "b61999b4-0fe8-49eb-b85c-56a7fa814cde", "score": null, "section": "orgasm-pleasure", "metadata": {}, "created_at": "2025-08-19T16:03:02.772074+00:00", "updated_at": "2025-08-19T16:03:03.988986+00:00", "question_id": "partner-orgasm", "assessment_id": "303acc06-3e3d-4f42-9bae-1f9fbb080286", "question_text": "How important is it that you are able to help your partner reach orgasm?", "response_type": "text", "response_value": "I am not sure this should be my responsibility"}, {"id": "9326a941-b13c-4f08-b496-78e2b935d002", "score": null, "section": "orgasm-pleasure", "metadata": {}, "created_at": "2025-08-19T16:03:08.144264+00:00", "updated_at": "2025-08-19T16:03:16.685782+00:00", "question_id": "masturbation", "assessment_id": "303acc06-3e3d-4f42-9bae-1f9fbb080286", "question_text": "What are your thoughts about masturbation within marriage?", "response_type": "text", "response_value": "Believe this is not appropriate for married Christians"}]}, "frequency-desire": {"count": 0, "total": 0, "average": 0, "responses": [{"id": "878dd65c-eece-4a3f-8ed9-e12370205c23", "score": null, "section": "frequency-desire", "metadata": {}, "created_at": "2025-08-19T16:03:33.175497+00:00", "updated_at": "2025-08-19T16:03:34.337637+00:00", "question_id": "frequency", "assessment_id": "303acc06-3e3d-4f42-9bae-1f9fbb080286", "question_text": "How often do you realistically want to have sex in marriage?", "response_type": "text", "response_value": "I have no idea what to expect for myself"}, {"id": "c42dbb32-260b-4e83-924c-1b7f9a55e420", "score": null, "section": "frequency-desire", "metadata": {}, "created_at": "2025-08-19T16:03:35.849773+00:00", "updated_at": "2025-08-19T16:03:36.958573+00:00", "question_id": "higher-desire-partner", "assessment_id": "303acc06-3e3d-4f42-9bae-1f9fbb080286", "question_text": "What if your partner wants sex significantly more often than you do?", "response_type": "text", "response_value": "I would worry there is something wrong with me"}, {"id": "5df3c4bb-c07e-4547-a0ec-8237436e33eb", "score": null, "section": "frequency-desire", "metadata": {}, "created_at": "2025-08-19T16:03:38.093872+00:00", "updated_at": "2025-08-19T16:03:39.240812+00:00", "question_id": "lower-desire-partner", "assessment_id": "303acc06-3e3d-4f42-9bae-1f9fbb080286", "question_text": "What if your partner wants sex significantly less often than you do?", "response_type": "text", "response_value": "I would worry they do not find me attractive"}, {"id": "e9f66a92-8238-41f9-a2fe-12287e63c167", "score": null, "section": "frequency-desire", "metadata": {}, "created_at": "2025-08-19T16:03:40.345566+00:00", "updated_at": "2025-08-19T16:03:41.419153+00:00", "question_id": "initiation", "assessment_id": "303acc06-3e3d-4f42-9bae-1f9fbb080286", "question_text": "How do you want to communicate when you are interested in having sex?", "response_type": "text", "response_value": "I am not sure how I will feel about initiating sex"}, {"id": "305ae325-b704-4c29-a315-d28965900cb6", "score": null, "section": "frequency-desire", "metadata": {}, "created_at": "2025-08-19T16:03:42.39939+00:00", "updated_at": "2025-08-19T16:03:43.577136+00:00", "question_id": "rejection", "assessment_id": "303acc06-3e3d-4f42-9bae-1f9fbb080286", "question_text": "What if you are not in the mood for sex when your partner initiates?", "response_type": "text", "response_value": "I would expect my partner to respect my no without question"}]}, "sexual-knowledge": {"count": 0, "total": 0, "average": 0, "responses": [{"id": "aec019b3-ebd4-4513-a8d6-4539238d903e", "score": null, "section": "sexual-knowledge", "metadata": {}, "created_at": "2025-08-19T16:02:20.045651+00:00", "updated_at": "2025-08-19T16:02:21.329088+00:00", "question_id": "sexual-experience-virginity", "assessment_id": "303acc06-3e3d-4f42-9bae-1f9fbb080286", "question_text": "Are you a virgin, and have you and your partner discussed what virginity means to each of you?", "response_type": "text", "response_value": "Yes, I am a virgin and my partner knows this"}, {"id": "f93b13a2-0988-4be7-8d60-63e855f31b9d", "score": null, "section": "sexual-knowledge", "metadata": {}, "created_at": "2025-08-19T16:02:22.72532+00:00", "updated_at": "2025-08-19T16:02:23.969529+00:00", "question_id": "knowledge-level", "assessme